<?xml version="1.0" encoding="utf-8"?>
<!-- modern_ux_theme_global/views/assets.xml -->
<odoo>
    <!-- Variáveis primárias (cores) -->
    <template id="assets_primary_variables" 
              inherit_id="web._assets_primary_variables" 
              priority="5">
        <xpath expr="." position="prepend">
            <link rel="stylesheet" 
                  href="/modern_ux_theme_global/static/src/scss/_variables_global.scss"/>
        </xpath>
    </template>
    
    <!-- Estilos gerais (backend) -->
    <template id="assets_backend" 
              inherit_id="web.assets_backend" 
              priority="10">
        <xpath expr="." position="append">
            <link rel="stylesheet" 
                  href="/modern_ux_theme_global/static/src/scss/main.scss"/>
        </xpath>
    </template>
    
    <!-- Estilos gerais (frontend/login) -->
    <template id="assets_frontend" 
              inherit_id="web.assets_frontend" 
              priority="10">
        <xpath expr="." position="append">
            <link rel="stylesheet" 
                  href="/modern_ux_theme_global/static/src/scss/main.scss"/>
        </xpath>
    </template>
</odoo>
